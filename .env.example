# UNMAPPED environment variables
# Copy to .env and fill in values. Never commit .env.

# ── Country selection (required) ─────────────────────────────────────────────
ACTIVE_COUNTRY=ghana   # ghana | bangladesh | <any configs/*.yaml stem>

# ── LLM (required for skills interview + voice) ──────────────────────────────
GROQ_API_KEY=gsk_...

# ── Google Gemini (optional — enables certificate photo scanning) ─────────────
GEMINI_API_KEY=                # from aistudio.google.com, free tier available

# ── Security (required in production) ────────────────────────────────────────
SECRET_KEY=change-me-in-production   # HMAC key for employer reveal tokens

# ── Telegram (required for bot) ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=...
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook

# ── SMS peer vouching (optional — mock used if not set) ──────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── App settings ─────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
APP_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO

# ── Database (SQLite for demo, Postgres for production) ──────────────────────
DATABASE_URL=sqlite+aiosqlite:///./unmapped.db
# DATABASE_URL=postgresql+asyncpg://user:pass@host/unmapped
